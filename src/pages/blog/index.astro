---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog">
  <h1 style="margin-top:0;">Blog</h1>
  {posts.map((post) => (
    <article style="margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid #eee;">
      <h2 style="margin-bottom:0.25rem;"><a href={`/blog/${post.id.replace(/\.md$/, '')}/`}>{post.data.title}</a></h2>
      <small style="color:#666;">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</small>
      {post.data.description && <p style="margin-top:0.5rem;color:#555;">{post.data.description}</p>}
    </article>
  ))}
</BaseLayout>
