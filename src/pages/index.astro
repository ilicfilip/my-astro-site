---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Home">
  <h1 style="margin-top:0;">Welcome</h1>
  <h2>Recent Posts</h2>
  {posts.length > 0 ? (
    <ul>
      {posts.map((post) => (
        <li style="margin-bottom:1rem;">
          <a href={`/blog/${post.id.replace(/\.md$/, "")}/`}>{post.data.title}</a>
          <br /><small style="color:#666;">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</small>
        </li>
      ))}
    </ul>
  ) : (
    <p>No posts yet. Open the editor and create your first post!</p>
  )}
</BaseLayout>
